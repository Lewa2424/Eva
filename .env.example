############################
# ЕВА 2.0 — ПЕРЕМЕННЫЕ СРЕДЫ
# Каждая переменная описана.
# Этот файл — шаблон (.env.example).
# Реальные значения хранятся в .env (НЕ коммитится).
############################


############################
# LLM / ЯЗЫКОВЫЕ МОДЕЛИ
############################

# API-ключ для доступа к OpenAI
# Используется LLM Proxy для общения с моделями
OPENAI_API_KEY=__PUT_YOUR_KEY_HERE__

# Модель для диалога, рассуждений, планирования и объяснений
# Используется для общения с пользователем и логического анализа
OPENAI_CHAT_MODEL=gpt-4o

# Модель для генерации, рефакторинга и анализа кода
# Используется строго для code-generation и тестов
OPENAI_CODE_MODEL=gpt-5.2


############################
# БАЗА ДАННЫХ (ПАМЯТЬ ЕВЫ)
############################

# Строка подключения к PostgreSQL
# Основная долговременная память Евы:
# задачи, планы, версии кода, метрики, рефлексия
POSTGRES_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Пример (локально):
# postgresql://eva:eva@localhost:5432/eva2


############################
# ПЕСОЧНИЦА / БЕЗОПАСНОСТЬ
############################

# Режим работы песочницы по умолчанию
# SAFE   — без сети, жёсткие ограничения (по умолчанию)
# FETCH  — временно разрешена сеть (установка зависимостей)
# ONLINE — сеть разрешена полностью (только по решению DecisionEngine)
SANDBOX_MODE=SAFE


############################
# ОБЩИЕ НАСТРОЙКИ СИСТЕМЫ
############################

# Режим работы Евы:
# development — активные логи, проверки, отладка
# production  — минимальные логи, стабильная работа
EVA_MODE=development

# Максимальный размер одного файла (строк)
# Используется как архитектурное ограничение
# для облегчения самомодификации и анализа
MAX_FILE_LINES=500
